{
  "name": "flex-cms",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "watch": "npx @tailwindcss/cli -i ./assets/css/app.css -o ./public/css/style.css --watch",
    "build": "npx @tailwindcss/cli -i ./assets/css/app.css -o ./public/css/style.css --minify",
    "dev": "npm run migrate:status && npm run watch",
    "migrate": "php vendor/bin/phinx migrate",
    "rollback": "php vendor/bin/phinx rollback",
    "migrate:create": "php vendor/bin/phinx create",
    "migrate:status": "php vendor/bin/phinx status"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
